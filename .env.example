PRIVATE_KEY=0xyourprivatekey
ARBITRAGE_CONTRACT=0xYourDeployedContract
# Everything below already has sane defaults in code.
# In practice you only need to fill PRIVATE_KEY and ARBITRAGE_CONTRACT.
RPC_URLS=https://arb1.arbitrum.io/rpc,https://arbitrum.blockpi.network/v1/rpc/public,https://rpc.ankr.com/arbitrum
BOT_EXECUTOR=
# AAVE_POOL_ADDRESSES_PROVIDER is no longer needed for deployment because
# the contract hardcodes the Arbitrum Aave v3 provider for Remix/Hardhat simplicity.
MIN_PROFIT_USDC=10
MAX_TRADE_SIZE_USDC=10000
SLIPPAGE_BPS=30
SIMULATION_SLIPPAGE_BPS=50
SCAN_INTERVAL_MS=10000
DEADLINE_SECONDS=90
GAS_LIMIT_BUFFER_BPS=12000
EMERGENCY_STOP=false
EMERGENCY_STOP_FILE=.emergency-stop
